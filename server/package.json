{
  "name": "gantry",
  "version": "1.0.0",
  "description": "MCP proxy and live dashboard for Space Molt AI fleets",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/geleynse/gantry.git"
  },
  "keywords": ["mcp", "ai-agents", "space-molt", "model-context-protocol", "proxy", "dashboard"],
  "author": "Alan Geleynse",
  "license": "MIT",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "build:server": "bun run build.ts",
    "build:client": "bun run next build",
    "build": "bun run build:server && bun run build:client",
    "build:binary": "bun run build:client && bun run build.ts --binary",
    "start": "bun dist/index.js",
    "dev": "bun run build.ts --watch",
    "dev:client": "bun run next dev --port 3001",
    "test": "bun test --max-concurrency=1",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@tailwindcss/postcss": "^4.2.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "lucide-react": "^0.575.0",
    "next": "^15.5.12",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "recharts": "^3.7.0",
    "socks": "^2.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.10",
    "esbuild": "^0.25.0",
    "happy-dom": "^20.7.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0"
  }
}