      "faction": "solarian",
      "notes": "Overflow account. Assign when adding a 3rd active agent."
    }
  ],

  "config": {
    "_comment": "Account pool behavior settings",
    "autoAssign": true,
    "_autoAssign_comment": "When true, Gantry assigns 'available' accounts to agents without explicit credentials at startup.",
    "matchFaction": true,
    "_matchFaction_comment": "When true, Gantry prefers assigning accounts whose faction matches the agent's faction in gantry.json.",
    "releaseOnShutdown": true,
    "_releaseOnShutdown_comment": "When true, agent assignments are cleared on clean shutdown. Accounts return to 'available'. Useful if agent names change between runs.",
    "maxAssignmentsPerAccount": 1,
    "_maxAssignmentsPerAccount_comment": "Safety guard — prevents one account from being assigned to multiple agents simultaneously."
  }
}
